<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  
  # Redirection spécifique pour l'admin vers le format Hash (HashRouter)
  # Pour éviter les 404 sur les anciens liens directs
  RewriteRule ^admin/(.*)$ /#/admin/$1 [R=301,L,NE]
  RewriteRule ^admin$ /#/admin/ [R=301,L,NE]

  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME} !-l
  RewriteRule . /index.html [L]
</IfModule>

# --- PERFORMANCE: CACHING ---
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresDefault "access plus 1 month"
  
  # Page HTML : Pas de cache pour garantir les mises à jour
  ExpiresByType text/html "access plus 0 seconds"
  
  # Médias : Cache long (1 an)
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 month"
  
  # Assets Statiques (Versionnés via Vite)
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

# --- PERFORMANCE: GZIP COMPRESSION ---
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>

# --- BLINDAGE SÉCURITÉ ---
# Empêcher le listage des dossiers
Options -Indexes

# Bloquer l'accès aux fichiers sensibles
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>
<FilesMatch "^(wp-config\.php|config\.php|\.env|\.git|composer\.)">
    Order allow,deny
    Deny from all
</FilesMatch>

# En-têtes de sécurité
<IfModule mod_headers.c>
  Header set X-XSS-Protection "1; mode=block"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set X-Content-Type-Options "nosniff"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set X-Permitted-Cross-Domain-Policies "none"
  
  # HSTS - Force HTTPS (365 jours)
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
  
  # Content Security Policy - Version Robuste
  Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://www.googletagmanager.com https://www.google-analytics.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https: blob:; connect-src 'self' https://esendnuisibles.fr https://site-test.esendnuisibles.fr https://www.google-analytics.com; frame-ancestors 'self';"
  
  # Permissions Policy
  Header set Permissions-Policy "geolocation=(), camera=(), microphone=(), payment=()"
  
  # Cross-Origin Policies
  Header set Cross-Origin-Embedder-Policy "unsafe-none"
  Header set Cross-Origin-Opener-Policy "same-origin"
  Header set Cross-Origin-Resource-Policy "same-origin"
</IfModule>
